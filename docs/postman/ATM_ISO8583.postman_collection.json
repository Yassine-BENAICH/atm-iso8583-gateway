      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('contains host and port', function () {",
              "  pm.expect(body).to.have.property('host');",
              "  pm.expect(body).to.have.property('port');",
              "});"
            ]
          }
        }
