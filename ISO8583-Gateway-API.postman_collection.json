							},
							{
								"key": "X-Request-ID",
								"value": "REQ-ERR-{{$randomUUID}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mti\": \"0200\",\n  \"transactionRef\": \"TXN-ERR-{{$timestamp}}\",\n  \"fields\": {\n    \"2\": \"4111111111111111\",\n    \"3\": \"000000\",\n    \"4\": \"000000999999\",\n    \"7\": \"{{$timestamp}}\",\n    \"11\": \"{{$randomInt}}\",\n    \"12\": \"103045\",\n    \"13\": \"0312\",\n    \"41\": \"ATM00001\",\n    \"49\": \"504\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/iso8583/send",
							"host": [
