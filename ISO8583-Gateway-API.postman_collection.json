{
	"info": {
		"_postman_id": "iso8583-gateway-api",
		"name": "ISO 8583 Gateway API",
		"description": "REST API for ISO 8583 message processing - Converts JSON requests to ISO 8583 format and communicates with payment switches",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Transactions",
			"item": [
				{
					"name": "Balance Inquiry",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-ID",
								"value": "REQ-BAL-{{$randomUUID}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mti\": \"0200\",\n  \"transactionRef\": \"TXN-BAL-{{$timestamp}}\",\n  \"fields\": {\n    \"2\": \"4111111111111111\",\n    \"3\": \"310000\",\n    \"4\": \"000000000000\",\n    \"7\": \"{{$timestamp}}\",\n    \"11\": \"{{$randomInt}}\",\n    \"12\": \"103045\",\n    \"13\": \"0312\",\n    \"41\": \"ATM00001\",\n    \"49\": \"504\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/iso8583/send",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"iso8583",
								"send"
							]
						},
						"description": "Balance inquiry transaction (MTI 0200) - Processing code 310000, Currency: MAD (504)"
					},
					"response": []
				},
				{
					"name": "Cash Withdrawal",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-ID",
								"value": "REQ-WD-{{$randomUUID}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mti\": \"0200\",\n  \"transactionRef\": \"TXN-WD-{{$timestamp}}\",\n  \"fields\": {\n    \"2\": \"5500000000000004\",\n    \"3\": \"000000\",\n    \"4\": \"000000010000\",\n    \"7\": \"{{$timestamp}}\",\n    \"11\": \"{{$randomInt}}\",\n    \"12\": \"103050\",\n    \"13\": \"0312\",\n    \"37\": \"{{$randomInt}}\",\n    \"41\": \"ATM00001\",\n    \"49\": \"504\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/iso8583/send",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"iso8583",
								"send"
							]
						},
						"description": "Cash withdrawal transaction (MTI 0200) - Processing code 000000, Amount: 100.00 MAD"
					},
					"response": []
				},
				{
					"name": "Purchase Transaction",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Request-ID",
								"value": "REQ-PUR-{{$randomUUID}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mti\": \"0200\",\n  \"transactionRef\": \"TXN-PUR-{{$timestamp}}\",\n  \"fields\": {\n    \"2\": \"4111111111111111\",\n    \"3\": \"000000\",\n    \"4\": \"000000025000\",\n    \"7\": \"{{$timestamp}}\",\n    \"11\": \"{{$randomInt}}\",\n    \"12\": \"103045\",\n    \"13\": \"0312\",\n    \"37\": \"{{$randomInt}}\",\n    \"41\": \"POS00001\",\n    \"49\": \"504\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/iso8583/send",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"iso8583",
								"send"
							]
						},
						"description": "Purchase transaction (MTI 0200) - Amount: 250.00 MAD"
					},
					"response": []
				}
			],
			"description": "ISO 8583 transaction endpoints"
		},
