					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mti\": \"0200\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/iso8583/send",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
