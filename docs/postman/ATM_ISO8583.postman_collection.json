  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function pad2(v) { return String(v).padStart(2, '0'); }",
          "function utcMMDDHHMMSS(date) {",
          "  return pad2(date.getUTCMonth() + 1) +",
          "         pad2(date.getUTCDate()) +",
          "         pad2(date.getUTCHours()) +",
          "         pad2(date.getUTCMinutes()) +",
          "         pad2(date.getUTCSeconds());",
          "}",
          "function localHHMMSS(date) {",
          "  return pad2(date.getHours()) +",
          "         pad2(date.getMinutes()) +",
          "         pad2(date.getSeconds());",
          "}",
          "function localMMDD(date) {",
          "  return pad2(date.getMonth() + 1) + pad2(date.getDate());",
          "}",
          "const now = new Date();",
          "const stan = String(Math.floor(Math.random() * 1000000)).padStart(6, '0');",
          "const rrn = String(Date.now()).slice(-12);",
          "pm.collectionVariables.set('stan', stan);",
          "pm.collectionVariables.set('transmissionDateTime', utcMMDDHHMMSS(now));",
          "pm.collectionVariables.set('localTime', localHHMMSS(now));",
          "pm.collectionVariables.set('localDate', localMMDD(now));",
          "pm.collectionVariables.set('rrn', rrn);"
        ]
      }
    }
  ],
